{
  "name": "@interdomestik/database",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./constants": "./src/constants.ts",
    "./types": "./src/types.ts",
    "./client": "./src/client.ts",
    "./server": "./src/server.ts",
    "./db": "./src/db.ts",
    "./schema": "./src/schema.ts",
    "./tenant-security": "./src/tenant-security.ts",
    "./member-number": "./src/member-number.ts",
    "./claim-number": "./src/claim-number.ts"
  },
  "scripts": {
    "db:generate": "echo 'Skipping supabase gen types (using Drizzle)' && exit 0",
    "db:push": "supabase db push",
    "db:studio": "supabase studio",
    "migrate": "tsx src/migrate.ts",
    "generate": "drizzle-kit generate",
    "push": "drizzle-kit push",
    "studio": "drizzle-kit studio",
    "type-check": "tsc --noEmit",
    "test:rls": "tsx --test test/critical-rls-tables.test.ts test/rls-engaged.test.ts test/no-domain-db-admin-import.test.ts test/rls-coverage.test.ts test/seed-cleanup.test.ts",
    "seed:golden": "tsx src/seed.ts golden",
    "seed:workload": "tsx src/seed.ts workload",
    "seed:full": "tsx src/seed.ts full",
    "seed:e2e": "tsx src/seed.ts e2e",
    "seed:assert-e2e": "tsx src/seed-assert.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.101.1",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9"
  },
  "peerDependencies": {
    "next": ">=16.1.7"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^22.19.2",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.1",
    "drizzle-kit": "^0.31.10",
    "nanoid": "^5.1.7",
    "supabase": "^2.84.5",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0"
  }
}
