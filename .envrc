# Load local-only environment variables for shell commands.
#
# This file is safe to commit because it contains NO secrets; it simply points
# direnv at `.env.local`, which is gitignored.

# Pin repo commands to the Node version declared in `.nvmrc`.
export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
export NODE_VERSIONS="${NODE_VERSIONS:-${NVM_DIR}/versions/node}"
export NODE_VERSION_PREFIX="${NODE_VERSION_PREFIX:-v}"
use node

dotenv_if_exists .env.local
