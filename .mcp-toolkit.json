{
  "identity": {
    "repo": "interdomestik-crystal-home",
    "root": "/Users/arbenlila/development/interdomestik-crystal-home",
    "devPort": 3000,
    "ownedMcpServers": ["interdomestik_qa"]
  },
  "repoContext": {
    "allowList": ["apps/**", "packages/**", "supabase/**"],
    "excludePatterns": ["**/node_modules/**", "**/.next/**", "**/dist/**", "**/.turbo/**"]
  },
  "qa": {
    "buildHealth": ["pnpm lint", "pnpm type-check", "pnpm build"],
    "testSuites": {
      "smoke": "pnpm --filter @interdomestik/web test:e2e -- --grep smoke",
      "unit": "pnpm --filter @interdomestik/web test:unit --run",
      "coverage": "pnpm --filter @interdomestik/web test:unit -- --coverage",
      "e2e": "pnpm --filter @interdomestik/web test:e2e"
    },
    "navigationAudit": "pnpm --filter @interdomestik/web test:e2e -- --grep smoke"
  },
  "e2e": {
    "baseUrl": "http://localhost:3000",
    "artifactRoot": "apps/web/test-results",
    "mcpProfile": "/tmp/interdomestik-pilot-evidence/playwright-mcp-profile",
    "mcpOutput": "/tmp/interdomestik-pilot-evidence/playwright-mcp-output",
    "defaultLocale": "sq",
    "locales": ["sq", "en"],
    "localePrefix": "always"
  }
}
